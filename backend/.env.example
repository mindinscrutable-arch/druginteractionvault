# ─── DATABASE ─────────────────────────────────────────────────────────────────
# Format: postgresql+psycopg://user:password@host:port/dbname
DATABASE_URL="postgresql+psycopg://postgres:your_password_here@localhost:5432/druginteractionvault"

# ─── GEMINI AI ────────────────────────────────────────────────────────────────
# Required for "Ask the Vault" chatbot and the NLP seeding pipeline
GEMINI_API_KEY="your_gemini_api_key_here"

# Gemini model to use — applies to both the chatbot and nlp_extractor.py
GEMINI_MODEL="gemini-1.5-flash"

# Max FDA label characters sent to Gemini prompt in nlp_extractor.py
MAX_FDA_LABEL_CHARS="2500"

# Seconds to sleep between Gemini API calls to respect free-tier RPM limits
GEMINI_RPM_DELAY="4.5"

# ─── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins. In production, set to your domain.
ALLOWED_ORIGINS="http://localhost:5173,http://localhost:3000"

# ─── CLINICAL RISK SCORING (optional tuning) ──────────────────────────────────
# Points deducted from 100 per interaction found (lower = more conservative)
SCORE_DEDUCTION_CONTRAINDICATED="40"
SCORE_DEDUCTION_SEVERE="25"
SCORE_DEDUCTION_MODERATE="12"
SCORE_DEDUCTION_MILD="5"

# Cascade weights — additive score across all interactions
# When total cascade score crosses a threshold, overall severity is escalated
CASCADE_WEIGHT_CONTRAINDICATED="50"
CASCADE_WEIGHT_SEVERE="10"
CASCADE_WEIGHT_MODERATE="3"
CASCADE_WEIGHT_MILD="1"

# Cascade escalation thresholds
CASCADE_CONTRAINDICATED_THRESHOLD="50"
CASCADE_SEVERE_THRESHOLD="10"
CASCADE_MODERATE_THRESHOLD="6"

# ─── EMAIL (Verification Codes) ───────────────────────────────────────────────
# Gmail SMTP settings are used by default in email_service.py
# Use a Gmail App Password, not your regular account password
EMAIL_USER="your-email@gmail.com"
EMAIL_PASS="your-16-digit-app-password"
